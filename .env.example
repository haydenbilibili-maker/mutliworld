# Multi World · 寰宇态势感知平台
# 复制为 .env.local 后按需修改

# ── 管理后台 ────────────────────────────────────────────────────────────────
# 开发环境 (npm run dev) 默认已启用管理后台，无需设置。
# 生产环境若需开放 /admin，请设为 true：
NEXT_PUBLIC_ADMIN_ENABLED=false

# ── 地图底图（地表自然地理样式，可选）────────────────────────────────────────
# 默认 OpenFreeMap Fiord（无需 Key）：水体/陆地/自然要素
# 可换 MapTiler Outdoor 等（需自备 Key）：
# NEXT_PUBLIC_MAP_STYLE_SURFACE=https://api.maptiler.com/maps/outdoor-v2/style.json?key=YOUR_KEY
# 地形增强（山体阴影 + 3D DEM，默认开启）：
# NEXT_PUBLIC_MAP_TERRAIN_ENHANCE=false

# 匿名访问有速率限制；注册账号后可提高配额：
# https://opensky-network.org/index.php?option=com_users&view=registration
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=

# ── OSINT：五角大楼披萨指数（可选）──────────────────────────────────────────
# pizzint.watch 无公开 REST API；默认使用服务端模拟演示数据。
# 若自建代理或获第三方授权，可设置 URL 以接入实时源：
# PIZZINT_API_URL=https://your-proxy.example.com/pizza-index

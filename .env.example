# Multi World · 寰宇态势感知平台
# 复制为 .env.local 后按需修改

# ── 管理后台 ────────────────────────────────────────────────────────────────
# 开发环境 (npm run dev) 默认已启用管理后台，无需设置。
# 生产环境若需开放 /admin，请设为 true：
NEXT_PUBLIC_ADMIN_ENABLED=false

# ── 地图底图（按空间层，可选）────────────────────────────────────────────────
# 洋底空间层：OpenFreeMap Fiord 自然地理样式（默认，无需 Key）
# NEXT_PUBLIC_MAP_STYLE_SURFACE=https://tiles.openfreemap.org/styles/fiord
# 地表/宇宙层政区样式（默认 OpenFreeMap Liberty）：
# NEXT_PUBLIC_MAP_STYLE_POLITICAL=https://tiles.openfreemap.org/styles/liberty
# 洋底层地形增强（Fiord + Terrarium DEM 山体阴影/3D，默认开启）：
# NEXT_PUBLIC_MAP_TERRAIN_ENHANCE=false
# 自定义 DEM 瓦片（Terrarium RGB 或 TileJSON）：
# NEXT_PUBLIC_MAP_TERRAIN_TILES=https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png

# 地表/宇宙底图模式（卫星/政区/混合）通过 UI 或 URL ?basemap=satellite|political|hybrid 切换。
# 卫星影像默认 ESRI World Imagery（无 Key；生产请核对 Esri ToS）。

# 匿名访问有速率限制；注册账号后可提高配额：
# https://opensky-network.org/index.php?option=com_users&view=registration
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=

# ── 实时天气（可选）──────────────────────────────────────────────────────────
# 默认 Open-Meteo（城市实况）+ RainViewer（降水雷达），无需 Key。
# 若需自定义 RainViewer 代理或禁用雷达，可在 src/app/api/weather 路由中调整。

# ── OSINT：五角大楼披萨指数（可选）──────────────────────────────────────────
# 默认从 https://www.pizzint.watch/api/dashboard-data 拉取实时数据。
# 覆盖 API 基址（不含路径）时使用：
# PIZZINT_API_URL=https://www.pizzint.watch

# ── 全球海运实时 AIS（可选）──────────────────────────────────────────────────
# 默认使用航运通道结构化模拟（马六甲、苏伊士、巴拿马、霍尔木兹、东海等）。
# 免费注册 AISStream 获取 Key 后可切换为近实时 AIS：
# https://aisstream.io
# AISSTREAM_API_KEY=

# Multi World · 寰宇态势感知平台
# 复制为 .env.local 后按需修改

# ── 管理后台 ────────────────────────────────────────────────────────────────
# 开发环境 (npm run dev) 默认已启用管理后台，无需设置。
# 生产环境若需开放 /admin，请设为 true：
NEXT_PUBLIC_ADMIN_ENABLED=false

# ── 地图底图（按空间层，可选）────────────────────────────────────────────────
# 洋底空间层：OpenFreeMap Fiord 自然地理样式（默认，无需 Key）
# NEXT_PUBLIC_MAP_STYLE_SURFACE=https://tiles.openfreemap.org/styles/fiord
# 地表/宇宙层政区样式（默认 OpenFreeMap Liberty）：
# NEXT_PUBLIC_MAP_STYLE_POLITICAL=https://tiles.openfreemap.org/styles/liberty
# 洋底层地形增强（Fiord + Terrarium DEM 山体阴影/3D，默认开启）：
# NEXT_PUBLIC_MAP_TERRAIN_ENHANCE=false
# 自定义 DEM 瓦片（Terrarium RGB 或 TileJSON）：
# NEXT_PUBLIC_MAP_TERRAIN_TILES=https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png

# 地表/宇宙底图模式（卫星/政区/混合）通过 UI 或 URL ?basemap=satellite|political|hybrid 切换。
# 卫星影像默认 ESRI World Imagery（无 Key；生产请核对 Esri ToS）。

# 匿名访问有速率限制；注册账号后可提高配额：
# https://opensky-network.org/index.php?option=com_users&view=registration
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=

# ── 实时天气（可选）──────────────────────────────────────────────────────────
# 默认 Open-Meteo（城市实况）+ RainViewer（降水雷达），无需 Key。
# 若需自定义 RainViewer 代理或禁用雷达，可在 src/app/api/weather 路由中调整。

# ── 能源经济真实数据（可选，强烈建议配置）──────────────────────────────────
# FRED 美联储经济数据库：布伦特/WTI/天然气/VIX/利率/汇率/CPI/失业率（日月频真实序列）
# 免费申请（邮箱即领，无信用卡）：https://fredaccount.stlouisfed.org/apikeys
# FRED_API_KEY=
#
# EIA 美国能源信息署：原油库存/产量、天然气库存等能源实物供需（周频真实）
# 免费申请：https://www.eia.gov/opendata/register.php
# EIA_API_KEY=
#
# 说明：二者均为服务端变量（勿加 NEXT_PUBLIC_ 前缀）；未配置时该源优雅降级，
#       World Bank(宏观) 与 Stooq(股指) 无需 Key，始终可用。绝不以假值填充。

# ── 实时火点 NASA FIRMS（可选）────────────────────────────────────────────
# VIIRS 近实时活跃火点。免费申请 MAP_KEY（服务端变量，勿加 NEXT_PUBLIC 前缀）：
# https://firms.modaps.eosdis.nasa.gov/api/area/
# 未配置时火点图层返回空并提示 noKey。
# FIRMS_MAP_KEY=

# ── OSINT：五角大楼披萨指数（可选）──────────────────────────────────────────
# 默认从 https://www.pizzint.watch/api/dashboard-data 拉取实时数据。
# 覆盖 API 基址（不含路径）时使用：
# PIZZINT_API_URL=https://www.pizzint.watch

# ── 全球海运实时 AIS（可选）──────────────────────────────────────────────────
# 默认使用航运通道结构化模拟（马六甲、苏伊士、巴拿马、霍尔木兹、东海等）。
# 免费注册 AISStream 获取 Key 后可切换为近实时 AIS：
# https://aisstream.io
# AISSTREAM_API_KEY=

# ── 区域简报 LLM 化（可选）──────────────────────────────────────────────────
# 区域简报「✨ AI 态势简报」按需生成，仅在区域真实数据上合成、保留来源、不编造。
# OpenAI 兼容端点；缺 Key 时该功能优雅降级（回落规则化简报）。
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ── 多天体探索 · 月球/火星底图瓦片（可选）──────────────────────────────────
# 地形图（默认 OpenPlanetaryMap，真实 MOLA/LRO 地形，开箱即用）。可覆盖为 NASA Trek/USGS/OPM。
# NEXT_PUBLIC_MOON_TILE_URL=https://.../{z}/{x}/{y}.png
# NEXT_PUBLIC_MARS_TILE_URL=https://.../{z}/{x}/{y}.png
#
# 卫星实拍底图（写实影像，Viking/CTX 等 Web Mercator XYZ 源）。配置后底部「🛰️ 实拍」切换生效；
# 未配置时实拍模式自动回落地形图。瓦片不可用时降级为纯色球面、痕迹照常显示。
# NEXT_PUBLIC_MOON_IMAGERY_URL=https://.../{z}/{x}/{y}.png
# NEXT_PUBLIC_MARS_IMAGERY_URL=https://.../{z}/{x}/{y}.png
